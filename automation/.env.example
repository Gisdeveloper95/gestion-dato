# ==============================================
# AUTOMATION SYSTEM - CONFIGURACION
# Copia este archivo a .env y ajusta los valores
# ==============================================

# === RUTAS DEL SISTEMA ===
AUTOMATION_DIR=/ruta/a/automation
SCRIPTS_DIR=/ruta/a/automation/scripts
LOGS_DIR=/ruta/a/automation/logs
CONFIG_DIR=/ruta/a/automation/config

# === AMBIENTE PYTHON ===
PYTHON_VENV=/ruta/a/automation/venv
PYTHON_BASE=/usr/bin/python3

# === USUARIO DEL SISTEMA ===
SERVICE_USER=usuario
SERVICE_GROUP=grupo

# === POSTGRESQL ===
DB_HOST=localhost
DB_NAME=base_datos
DB_USER=usuario
DB_PASSWORD=password
DB_PORT=5432

# === TELEGRAM BOT ===
TELEGRAM_TOKEN=123456789:ABC-token-aqui
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_SEND_LOGS=true

# === GROQ AI (opcional) ===
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1000
GROQ_TEMPERATURE=0.7

# === LIMPIEZA DE BD ===
CLEANUP_ENABLED=true
CLEANUP_RETENTION_MONTHS=4

# === LOGGING ===
LOG_LEVEL=INFO
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5
