# API Configuration
# URL completa del backend (incluye protocolo, host y puerto)
# Ejemplos:
# - Desarrollo local: http://localhost:8000
# - Producción: https://api.tudominio.com
VITE_API_URL=http://localhost:8000

# Server Configuration
# Host donde se ejecutará el servidor de desarrollo de Vite
# 0.0.0.0 permite acceso desde cualquier IP en la red local
VITE_SERVER_HOST=0.0.0.0

# Puerto del servidor de desarrollo (opcional, Vite usa 5173 por defecto)
VITE_SERVER_PORT=5173

# Allowed Hosts (separados por coma)
# Hosts permitidos para acceder al servidor de desarrollo
# Ejemplo: localhost,192.168.0.120,5000-218628.dcigac.local
VITE_ALLOWED_HOSTS=localhost

# Application Settings
VITE_APP_VERSION=1.0.0
VITE_LOG_LEVEL=info

# Environment
# Nota: Vite automáticamente establece MODE como 'development' o 'production'
# No es necesario configurarlo manualmente
