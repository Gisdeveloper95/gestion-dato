# ==============================================
# Configuración de Montaje NetApp (CIFS/SMB)
# Copiar a NETAPP_MOUNT.env y completar
# ==============================================

# === SERVIDOR NETAPP ===
NETAPP_SERVER_IP=172.21.54.13
NETAPP_SHARE_PATH=DirGesCat
NETAPP_MOUNT_POINT=/mnt/repositorio

# === CREDENCIALES WINDOWS ===
NETAPP_USERNAME=usuario.windows@dominio.com
NETAPP_PASSWORD=PASSWORD_SEGURO
NETAPP_DOMAIN=IGAC

# === OPCIONES DE MONTAJE ===
NETAPP_FILE_MODE=0775
NETAPP_DIR_MODE=0775
NETAPP_UID=1004
NETAPP_GID=1002

# === RUTA COMPLETA PARA FSTAB ===
# //${NETAPP_SERVER_IP}/${NETAPP_SHARE_PATH} ${NETAPP_MOUNT_POINT} cifs username=${NETAPP_USERNAME},password=${NETAPP_PASSWORD},uid=${NETAPP_UID},gid=${NETAPP_GID},file_mode=${NETAPP_FILE_MODE},dir_mode=${NETAPP_DIR_MODE} 0 0
