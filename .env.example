# ==============================================
# Archivo de ejemplo de variables de entorno
# Copia este archivo a .env y ajusta los valores
# ==============================================

# === BASE DE DATOS ===
DB_NAME=gestion_dato_db
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432

# === DJANGO BACKEND ===
DEBUG=False
SECRET_KEY=django-insecure-change-this-to-a-random-secret-key-in-production

# Para HTTP (desarrollo):
# ALLOWED_HOSTS=localhost,127.0.0.1,172.19.3.196

# Para HTTPS (producción con dominio):
ALLOWED_HOSTS=localhost,127.0.0.1,tudominio.com

# === PUERTOS ===
BACKEND_PORT=8000
FRONTEND_PORT=80

# === CORS Y CSRF ===
# Para HTTP (desarrollo):
# CORS_ALLOWED_ORIGINS=http://localhost:80,http://localhost:5173,http://172.19.3.196
# CSRF_TRUSTED_ORIGINS=http://localhost:80,http://localhost:5173,http://172.19.3.196

# Para HTTPS (producción con dominio):
CORS_ALLOWED_ORIGINS=https://tudominio.com
CSRF_TRUSTED_ORIGINS=https://tudominio.com

# === JWT TOKENS ===
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=180
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# === FRONTEND ===
# Para HTTP (desarrollo):
# VITE_API_URL=http://172.19.3.196:8000

# Para HTTPS (producción con dominio):
VITE_API_URL=https://tudominio.com

# === NETWORK SHARES (Opcional - ajusta según tu entorno) ===
REPOSITORY_BASE_PATH=/mnt/repository
PDF_REPOSITORY_PATH=/mnt/pdf_repository
REPOSITORY_USERNAME=
REPOSITORY_PASSWORD=
REPOSITORY_DOMAIN=
